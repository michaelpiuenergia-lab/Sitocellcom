# ============================================================================
# CRM API — fonte unica di verità per prodotti, stock, riparazioni, B2B, intake
# ============================================================================
# Quando entrambi sono settati, l'HUB usa il CRM reale per tutti gli endpoint
# (public/products, b2b/*, public/requests, b2b/requests). Se mancano, fallback
# automatico ai mock (lib/crm-client/mocks/*).
CRM_API_URL=<base URL del CRM, es. https://crm.cellcom.it>
CRM_API_KEY=<API key generata lato CRM, prefisso hub_prod_*>

# ============================================================================
# Override mock granulari (default: real quando CRM_API_URL è settato)
# ============================================================================
# Forza i mock anche con CRM configurato — utile per sviluppo offline o demo
# senza dipendenze esterne. Lasciare commentato in prod.
# USE_MOCK_PUBLIC=true     # mock /api/v1/public/products
# B2B_USE_MOCK=true        # mock /api/v1/b2b/* (login, me, products)
# REQUESTS_USE_MOCK=true   # mock /api/v1/public/requests + /api/v1/b2b/requests

# ============================================================================
# Revalidate webhook — il CRM chiama questa rotta quando cambia un prodotto
# ============================================================================
REVALIDATE_SECRET=generate-a-secure-secret-with-openssl-rand-base64-32

# ============================================================================
# Cookie sessione B2B (HMAC-SHA256). Min 32 caratteri.
# Generala con: openssl rand -base64 48
# ============================================================================
AUTH_COOKIE_SECRET=generate-a-secure-secret-with-openssl-rand-base64-48
